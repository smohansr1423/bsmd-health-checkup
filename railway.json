{
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "packages/api-gateway/Dockerfile"
  },
  "deploy": {
    "startCommand": "node packages/api-gateway/dist/index.js",
    "healthcheckPath": "/health",
    "healthcheckTimeout": 30,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}
